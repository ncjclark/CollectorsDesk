# eBay API — get from developer.ebay.com → My Account → Application Access Keys
# Sign in with your regular eBay account, create an app, copy the Production keyset
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_ENVIRONMENT=production

# Anthropic API — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Etsy API — get from developers.etsy.com → Create App (free)
# Gives access to active vintage listing prices
ETSY_API_KEY=

# App config — safe to leave as defaults
DATABASE_URL=sqlite:///./data/inventory.db
UPLOAD_DIR=./uploads
RESEARCH_CACHE_TTL_HOURS=24
MAX_EBAY_RESULTS=100
